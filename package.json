{
  "name": "gewehub",
  "private": true,
  "version": "0.1.0",
  "description": "GeWeHub 个微中枢 monorepo",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --filter './server' --filter './web' build",
    "dev": "pnpm --parallel --filter @gewehub/server --filter @gewehub/web dev",
    "lint": "pnpm -r --filter './packages/**' --filter './server' --filter './web' lint",
    "test": "pnpm -r --filter './packages/**' --filter './server' --filter './web' test",
    "typecheck": "pnpm -r --filter './packages/**' --filter './server' --filter './web' typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
